// FV Ribbon — USDCHF — Institutional V4 (15m chart)
// 15m verified: Sharpe 2.44 | 55 trades/60d | PF 1.40 | σ≥6° | 2 retest dots | RR 1:1.5
//@version=6
indicator("FV Ribbon [CHF V4]", shorttitle="FV CHF", overlay=true)

const float MIN_SIGMA = 1e-10
const float PI = 3.14159265359
const int YZ_LEN = 20
const int ANGLE_LB = 13
const int MA1_LENGTH = 10
const int MA2_LENGTH = 50
const float ANGLE_THRESH = 6.0
const int MAX_DOTS = 2
const bool FIRE_ROCKET = false
const float RR_TARGET = 1.5
const float ATR_SL_MULT = 1.5

fast_ma = ta.ema(close, MA1_LENGTH)
slow_ma = ta.sma(close, MA2_LENGTH)

ema20_4h = request.security(syminfo.tickerid, "240", ta.ema(close, 20)[1], barmerge.gaps_off, barmerge.lookahead_on)
ema50_4h = request.security(syminfo.tickerid, "240", ta.ema(close, 50)[1], barmerge.gaps_off, barmerge.lookahead_on)

dist_pct = math.abs(ema20_4h - ema50_4h) / ema50_4h * 100
prox_input = 0.25
allow_long = (ema20_4h > ema50_4h) or ((ema20_4h < ema50_4h) and (dist_pct <= prox_input) and (fast_ma > slow_ma))
allow_short = (ema20_4h < ema50_4h) or ((ema20_4h > ema50_4h) and (dist_pct <= prox_input) and (fast_ma < slow_ma))
bgcolor(allow_long ? color.new(#089981, 92) : allow_short ? color.new(#f23645, 92) : na)

min_slope = 0.03
bull_slope = (slow_ma - nz(slow_ma[5])) / nz(slow_ma[5]) * 100
bear_slope = (nz(slow_ma[5]) - slow_ma) / nz(slow_ma[5]) * 100
is_choppy_bull = bull_slope < min_slope
is_choppy_bear = bear_slope < min_slope

macro_atr = ta.atr(100)
safe_atr = math.max(macro_atr, 0.0001)
thrust_lookback = 3
thrust_req = 1.5
price_thrust_bull = (close - nz(close[thrust_lookback])) / safe_atr
price_thrust_bear = (nz(close[thrust_lookback]) - close) / safe_atr
is_rocket_bull = (fast_ma > slow_ma) and (price_thrust_bull >= thrust_req)
is_rocket_bear = (fast_ma < slow_ma) and (price_thrust_bear >= thrust_req)

gap_atr = math.abs(fast_ma - slow_ma) / safe_atr
req_gap = 0.5

pure_bg_bull = ema20_4h > ema50_4h
pure_bg_bear = ema20_4h < ema50_4h
is_ct_bull = pure_bg_bear
is_ct_bear = pure_bg_bull
ct_max_bars = 16
cross_over = ta.crossover(fast_ma, slow_ma)
cross_under = ta.crossunder(fast_ma, slow_ma)
bars_bull = ta.barssince(cross_over)
bars_bear = ta.barssince(cross_under)
ct_exhausted_bull = is_ct_bull and (bars_bull >= ct_max_bars)
ct_exhausted_bear = is_ct_bear and (bars_bear >= ct_max_bars)
disarm_bull = (close < slow_ma) or cross_under or ct_exhausted_bull
disarm_bear = (close > slow_ma) or cross_over or ct_exhausted_bear

std_bull = (fast_ma > slow_ma) and (gap_atr >= req_gap) and not is_choppy_bull
std_bear = (fast_ma < slow_ma) and (gap_atr >= req_gap) and not is_choppy_bear
trigger_bull = (std_bull or is_rocket_bull) and not ct_exhausted_bull
trigger_bear = (std_bear or is_rocket_bear) and not ct_exhausted_bear

_yzOR = math.log(open / nz(close[1], open))
_yzCO = math.log(close / open)
_yzHO = math.log(high / open)
_yzHC = math.log(high / close)
_yzLO = math.log(low / open)
_yzLC = math.log(low / close)
_sqOR = ta.variance(_yzOR, YZ_LEN)
_sqCO = ta.variance(_yzCO, YZ_LEN)
_sqRS = ta.sma(_yzHO * _yzHC + _yzLO * _yzLC, YZ_LEN)
_k = 0.34 / (1.34 + (YZ_LEN + 1.0) / math.max(YZ_LEN - 1.0, 1.0))
_sq = nz(_sqOR) + _k * nz(_sqCO) + (1.0 - _k) * nz(_sqRS)
sigma = math.max(math.sqrt(math.max(_sq, 0.0)), MIN_SIGMA)
_logC = math.log(close)
slopePB = (_logC - nz(_logC[ANGLE_LB])) / ANGLE_LB
icsAngle = math.atan(slopePB / sigma) * 180.0 / PI
ang_ok_bull = math.abs(icsAngle) >= ANGLE_THRESH and icsAngle > 0
ang_ok_bear = math.abs(icsAngle) >= ANGLE_THRESH and icsAngle < 0

var bool bull_ignited = false
var bool bear_ignited = false
if trigger_bull
    bull_ignited := true
if trigger_bear
    bear_ignited := true
if disarm_bull
    bull_ignited := false
if disarm_bear
    bear_ignited := false

color ribbon_color = bull_ignited ? color.new(#089981, 75) : bear_ignited ? color.new(#f23645, 75) : color.new(color.gray, 90)
p1 = plot(fast_ma, "Fast EMA", color=bull_ignited or bear_ignited ? #f6c309 : color.gray, linewidth=2)
p2 = plot(slow_ma, "Slow SMA", color=bull_ignited or bear_ignited ? #fb9800 : color.gray, linewidth=2)
fill(p1, p2, color=ribbon_color)

var int bull_hits = 0
var int bear_hits = 0
if not bull_ignited
    bull_hits := 0
if not bear_ignited
    bear_hits := 0

bull_dot = false
bear_dot = false
if barstate.isconfirmed
    if bull_ignited and ang_ok_bull and bull_hits < MAX_DOTS
        if (low <= fast_ma) and (close >= slow_ma)
            bull_dot := true
            bull_hits += 1
        else if FIRE_ROCKET and is_rocket_bull
            bull_dot := true
            bull_hits += 1
    if bear_ignited and ang_ok_bear and bear_hits < MAX_DOTS
        if (high >= fast_ma) and (close <= slow_ma)
            bear_dot := true
            bear_hits += 1
        else if FIRE_ROCKET and is_rocket_bear
            bear_dot := true
            bear_hits += 1

plotshape(bull_dot, title="Long Entry", style=shape.circle, location=location.belowbar, color=#089981, size=size.tiny)
plotshape(bear_dot, title="Short Entry", style=shape.circle, location=location.abovebar, color=#f23645, size=size.tiny)

risk_atr = ta.atr(14)
plot(nz(risk_atr, 0.0), "Risk ATR", display=display.none)

if barstate.isconfirmed and bull_dot
    label.new(bar_index, low, "L", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_up, color=#089981, textcolor=color.white, size=size.tiny)
if barstate.isconfirmed and bear_dot
    label.new(bar_index, high, "S", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_down, color=#f23645, textcolor=color.white, size=size.tiny)

alertcondition(bull_dot, "Long Entry", '{"ticker":"{{ticker}}","price":{{close}},"direction":"LONG","timeframe":"{{interval}}","risk_atr":{{plot_2}},"signal_time":{{time}},"rr_target":1.5,"atr_sl_mult":1.5,"secret_token":"hype_retest_2026"}')
alertcondition(bear_dot, "Short Entry", '{"ticker":"{{ticker}}","price":{{close}},"direction":"SHORT","timeframe":"{{interval}}","risk_atr":{{plot_2}},"signal_time":{{time}},"rr_target":1.5,"atr_sl_mult":1.5,"secret_token":"hype_retest_2026"}')
