// © FV Ribbon - Apex Ignition V26 (Dual Engine & Pure CT Matrix)

//@version=6
indicator("FV Ribbon [Apex Ignite V26]", shorttitle = "FV Apex V26", overlay = true)

//-----------------------------------------------------------------------------
// On-Chart MAs
//-----------------------------------------------------------------------------
ma1_length = input.int(20,  "Fast EMA Length")
ma2_length = input.int(50,  "Slow SMA Length")

fast_ma = ta.ema(close, ma1_length)
slow_ma = ta.sma(close, ma2_length)

//-----------------------------------------------------------------------------
// 4H Background Shield
//-----------------------------------------------------------------------------
ema20_4h = request.security(syminfo.tickerid, "240", ta.ema(close, 20))
ema50_4h = request.security(syminfo.tickerid, "240", ta.ema(close, 50))

// Visual proximity buffer for the background colors
dist_pct = math.abs(ema20_4h - ema50_4h) / ema50_4h * 100
prox_input = input.float(0.25, "Early Crossover Proximity (%)", step=0.05)

allow_long = (ema20_4h > ema50_4h) or ((ema20_4h < ema50_4h) and (dist_pct <= prox_input) and (fast_ma > slow_ma))
allow_short = (ema20_4h < ema50_4h) or ((ema20_4h > ema50_4h) and (dist_pct <= prox_input) and (fast_ma < slow_ma))

bgcolor(allow_long ? color.new(#089981, 92) : allow_short ? color.new(#f23645, 92) : na, title="4H Trend Background")

//-----------------------------------------------------------------------------
// --- ENGINE 1: CHOP KILLER (50 SMA Slope) ---
//-----------------------------------------------------------------------------
// In horizontal chop (like Asian session), the 50 SMA goes flat. This blocks signals.
min_slope = input.float(0.03, "Min 50 SMA Slope (%) - Blocks Chop", step=0.01)
bull_slope = (slow_ma - nz(slow_ma[5])) / nz(slow_ma[5]) * 100
bear_slope = (nz(slow_ma[5]) - slow_ma) / nz(slow_ma[5]) * 100

is_choppy_bull = bull_slope < min_slope
is_choppy_bear = bear_slope < min_slope

//-----------------------------------------------------------------------------
// --- ENGINE 2: PRICE ROCKET OVERRIDE ---
//-----------------------------------------------------------------------------
macro_atr = ta.atr(100)
safe_atr = math.max(macro_atr, 0.0001)

thrust_lookback = input.int(3, "Price Thrust Lookback (Bars)")
thrust_req = input.float(1.5, "Vertical Price Thrust Req (ATR)", step=0.1, tooltip="If raw price moves this many ATRs, it instantly ignites, bypassing the chop filter.")

// We measure the RAW PRICE thrust to instantly catch massive vertical rockets.
price_thrust_bull = (close - nz(close[thrust_lookback])) / safe_atr
price_thrust_bear = (nz(close[thrust_lookback]) - close) / safe_atr

is_rocket_bull = (fast_ma > slow_ma) and (price_thrust_bull >= thrust_req)
is_rocket_bear = (fast_ma < slow_ma) and (price_thrust_bear >= thrust_req)

//-----------------------------------------------------------------------------
// --- CORE GAP METRICS ---
//-----------------------------------------------------------------------------
gap_raw = math.abs(fast_ma - slow_ma)
gap_atr = gap_raw / safe_atr
req_gap = input.float(0.5, "Required Gap (Macro ATR)", step=0.1)

//-----------------------------------------------------------------------------
// --- THE COUNTER-TREND MATRIX (Pure 4H Logic) ---
//-----------------------------------------------------------------------------
// Strictly relies on the pure background direction, ignoring visual proximity buffers.
pure_bg_bull = ema20_4h > ema50_4h
pure_bg_bear = ema20_4h < ema50_4h

is_ct_bull = pure_bg_bear // A Long setup forming while the 4H is Red
is_ct_bear = pure_bg_bull // A Short setup forming while the 4H is Green

ct_max_bars = input.int(16, "Counter-Trend Max Duration (Bars)", tooltip="If opposing the HTF, forces ribbon to disarm after this many bars.")
bars_bull = ta.barssince(ta.crossover(fast_ma, slow_ma))
bars_bear = ta.barssince(ta.crossunder(fast_ma, slow_ma))

// Exhaustion Kill-Switches
ct_exhausted_bull = is_ct_bull and (bars_bull >= ct_max_bars)
ct_exhausted_bear = is_ct_bear and (bars_bear >= ct_max_bars)

//-----------------------------------------------------------------------------
// --- IGNITION TRIGGERS ---
//-----------------------------------------------------------------------------
// Trigger if (Engine 1 is valid OR Engine 2 is valid) AND we aren't exhausted.
std_bull = (fast_ma > slow_ma) and (gap_atr >= req_gap) and not is_choppy_bull
std_bear = (fast_ma < slow_ma) and (gap_atr >= req_gap) and not is_choppy_bear

trigger_bull = (std_bull or is_rocket_bull) and not ct_exhausted_bull
trigger_bear = (std_bear or is_rocket_bear) and not ct_exhausted_bear

//-----------------------------------------------------------------------------
// --- LATCH & LOCK-OPEN MEMORY ---
//-----------------------------------------------------------------------------
var bool bull_ignited = false
var bool bear_ignited = false

if trigger_bull
    bull_ignited := true
if trigger_bear
    bear_ignited := true

// The Latch is explicitly destroyed by Structural Death OR Counter-Trend Exhaustion
if (close < slow_ma) or ta.crossunder(fast_ma, slow_ma) or ct_exhausted_bull
    bull_ignited := false
if (close > slow_ma) or ta.crossover(fast_ma, slow_ma) or ct_exhausted_bear
    bear_ignited := false

// Visual Ribbon
color ribbon_color = bull_ignited ? color.new(#089981, 75) : bear_ignited ? color.new(#f23645, 75) : color.new(color.gray, 90)
p1 = plot(fast_ma, "Fast 20 EMA", color=bull_ignited or bear_ignited ? #f6c309 : color.gray, linewidth=2)
p2 = plot(slow_ma, "Slow 50 SMA", color=bull_ignited or bear_ignited ? #fb9800 : color.gray, linewidth=2)
fill(p1, p2, color=ribbon_color, title="Armed FV Zone")

//-----------------------------------------------------------------------------
// --- FIRST STRIKE EXECUTION (The Wick) ---
//-----------------------------------------------------------------------------
var int bull_hits = 0
var int bear_hits = 0

// Reset hits when the ribbon turns gray
if not bull_ignited
    bull_hits := 0
if not bear_ignited
    bear_hits := 0

bull_pierce = (low <= fast_ma)
bear_pierce = (high >= fast_ma)

bull_safe_close = (close >= slow_ma)
bear_safe_close = (close <= slow_ma)

bull_dot = false
bear_dot = false

if barstate.isconfirmed
    // We do NOT use allow_long here. The Counter-Trend matrix natively governs opposing trades now.
    if bull_ignited and bull_pierce and bull_safe_close and (bull_hits < 1)
        bull_dot := true
        bull_hits += 1

    if bear_ignited and bear_pierce and bear_safe_close and (bear_hits < 1)
        bear_dot := true
        bear_hits += 1

//-----------------------------------------------------------------------------
// Visual Markers & Alerts
//-----------------------------------------------------------------------------
plotshape(bull_dot, title="Bullish Fanned Retest", style=shape.circle, location=location.belowbar, color=#089981, size=size.tiny)
plotshape(bear_dot, title="Bearish Fanned Retest", style=shape.circle, location=location.abovebar, color=#f23645, size=size.tiny)

alertcondition(bull_dot, "Long Retest", "PA Safe. Check HTF Context and 1m Trinity.")
alertcondition(bear_dot, "Short Retest", "PA Safe. Check HTF Context and 1m Trinity.")